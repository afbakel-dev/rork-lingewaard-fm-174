{
  "expo": {
    "name": "Lingewaard FM",
    "slug": "ktuuj02rdlbrt4n1xf61q",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rork-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F18"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "lingewaard.radio.apl",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F0F18"
      },
      "package": "nl.lingewaard.radio",
      "versionCode": 1,
      "allowBackup": false,
      "googleServicesFile": null,
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "./plugins/withAirPlayOptimize"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}